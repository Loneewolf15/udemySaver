{
  "manifest_version": 3,
  "name": "Udemy Saver Extractor",
  "version": "1.0.0",
  "description": "Seamlessly extract your Udemy access_token and connect it to Udemy Saver.",
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "permissions": ["cookies", "tabs", "scripting"],
  "host_permissions": [
    "*://*.udemy.com/*",
    "*://localhost/*",
    "*://127.0.0.1/*"
  ]
}
